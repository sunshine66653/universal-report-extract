{
  "display_name": "HK English Reports",
  "language": "en",
  "report_period_hint": "the latest full reporting period (FY2024)",
  "llm": {
    "text_model": "qwen-plus",
    "vl_model": "qwen-vl-max",
    "temperature": 0.0,
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "max_chars_context": 32000
  },
  "chunking": {
    "strategy": "heading",
    "max_chars": 5000,
    "slice_marker_regex": "^\\s*#\\s*---\\s*(?:PDF\\s*Physical\\s*Slice|PDF\\s*物理切片)\\s*[:：]?\\s*(?:Pages?|第)\\s*(\\d+)\\s*-\\s*(\\d+)\\s*(?:页)?\\s*---\\s*$",
    "heading_levels": 6
  },
  "retrieval": {
    "topk": 14,
    "weights": {
      "alias": 4.0,
      "section_base": 3.0,
      "text_base": 2.0,
      "step": 1.0,
      "company": 10.0,
      "table": 1.0
    },
    "table_signals": ["Unit", "Item", "Current", "Prior", "Year", "%",
                      "HK$", "RMB", "USD", "Total", "Note"]
  },
  "convert": {
    "engine": "mineru",
    "rotate_detect": false,
    "mineru_token": "",
    "mineru_model_version": "vlm",
    "recognize_images": true
  },
  "rules_file": "rules/rules.xlsx",
  "download": {
    "adapter": "cninfo",
    "report_language": "en",
    "company_codes": {}
  }
}
